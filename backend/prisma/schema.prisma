generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Driver {
  id               Int       @id @default(autoincrement())
  name             String
  email            String    @unique
  phone            String
  password         String
  dcNumber         String    @unique
  taxiReg          String
  carModel         String
  resetToken       String?
  resetTokenExpiry DateTime?
  rides            Ride[]    @relation("DriverRides")
}

model Ride {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  email          String?
  note           String?
  pickup         String
  pickupLat      Float
  pickupLng      Float
  dropoff        String
  dropoffLat     Float
  dropoffLng     Float
  rideDate       DateTime
  passengerCount Int
  vehicleType    String
  fare           Float
  fareType       String
  createdAt      DateTime @default(now())
  driverId       Int?
  userId         Int?
  status         String   @default("upcoming")
  driver         Driver?  @relation("DriverRides", fields: [driverId], references: [id])
  user           User?    @relation(fields: [userId], references: [id])
  attributedSessions VisitSession[]
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  phone        String    @unique
  email        String?
  password     String
  createdAt    DateTime  @default(now())
  otpCode      String?
  otpExpiresAt DateTime?
  rides        Ride[]
}

model DriverInvite {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Blog {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  title      String
  subtitle   String?
  template   String
  image1     String
  image1Alt  String
  image2     String?
  image2Alt  String?
  image3     String?
  image3Alt  String?
  body1      String
  body2      String
  conclusion String
  createdAt  DateTime @default(now())
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
}

model Visitor {
  id               Int            @id @default(autoincrement())
  visitorToken     String         @unique
  firstSeenAt      DateTime       @default(now())
  lastSeenAt       DateTime       @default(now())
  firstSourceType  String?
  firstLandingPath String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  sessions         VisitSession[]
  events           VisitEvent[]
}

model VisitSession {
  id                  Int                     @id @default(autoincrement())
  sessionToken        String                  @unique
  visitorId           Int
  startedAt           DateTime                @default(now())
  endedAt             DateTime?
  landingUrl          String?
  landingPath         String?
  referrer            String?
  sourceType          String                  @default("direct")
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmTerm             String?
  utmContent          String?
  gclid               String?
  gbraid              String?
  wbraid              String?
  geoCity             String?
  geoRegion           String?
  geoCountry          String?
  isLikelyMelbourne   Boolean                 @default(false)
  ipHash              String?
  userAgent           String?
  browser             String?
  deviceType          String?
  screenWidth         Int?
  timezone            String?
  sessionDurationSec  Int                     @default(0)
  eventCount          Int                     @default(0)
  riskScore           Int                     @default(0)
  riskBand            String                  @default("good")
  riskReasonsJson     Json?
  attributedRideId    Int?
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  visitor             Visitor                 @relation(fields: [visitorId], references: [id])
  attributedRide      Ride?                   @relation(fields: [attributedRideId], references: [id])
  events              VisitEvent[]

  @@index([visitorId])
  @@index([startedAt])
  @@index([sourceType])
  @@index([gclid])
  @@index([ipHash])
  @@index([riskBand])
  @@index([landingPath])
}

model VisitEvent {
  id                 Int          @id @default(autoincrement())
  sessionId          Int
  visitorId          Int
  eventName          String
  eventTime          DateTime     @default(now())
  path               String?
  pageTitle          String?
  stepName           String?
  pickupSuburb       String?
  dropoffSuburb      String?
  isAirportPickup    Boolean?
  isAirportDropoff   Boolean?
  estimatedFare      Float?
  vehicleType        String?
  passengerCount     Int?
  bookingType        String?
  bookingDateTime    DateTime?
  clickTarget        String?
  clickLocation      String?
  metadataJson       Json?
  sourceTypeSnapshot String?
  createdAt          DateTime     @default(now())
  session            VisitSession @relation(fields: [sessionId], references: [id])
  visitor            Visitor      @relation(fields: [visitorId], references: [id])

  @@index([sessionId, eventTime])
  @@index([eventName, eventTime])
  @@index([pickupSuburb])
  @@index([dropoffSuburb])
}

model TrafficBlockSignal {
  id                    Int      @id @default(autoincrement())
  ipHash                String
  firstSeenAt           DateTime @default(now())
  lastSeenAt            DateTime @default(now())
  sessionCount          Int      @default(0)
  paidSessionCount      Int      @default(0)
  suspiciousSessionCount Int     @default(0)
  reason                String
  status                String   @default("open")
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@unique([ipHash, reason])
  @@index([status])
}

model VisitSecuritySnapshot {
  id          Int      @id @default(autoincrement())
  rawIp       String?
  ipHash      String?
  headersJson Json?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  @@index([expiresAt])
  @@index([ipHash])
}
